@charset "utf-8";

.switch[data-v-b063d6f3] { user-select: none; cursor: pointer; align-items: center; font-size: 12px; display: inline-flex; }

.switch.disabled[data-v-b063d6f3] { cursor: not-allowed; opacity: 0.4; }

.switch.disabled .switch-icon[data-v-b063d6f3] { cursor: not-allowed; background: var(--Fills-F3); }

.switch.disabled .switch-icon[data-v-b063d6f3]::before { background: var(--Others-WhiteOnDarkDisabled); }

.switch.disabled .switch-icon.open[data-v-b063d6f3] { background: var(--Others-KMBlueDisabled); }

.switch-hidden[data-v-b063d6f3] { display: none; }

.switch-icon[data-v-b063d6f3] { cursor: pointer; width: calc(var(--switch-size) * 2 + 4px); box-sizing: border-box; background: var(--Fills-F3); border-radius: 22px; padding: 2px; }

.switch-icon[data-v-b063d6f3]::before { content: ""; width: var(--switch-size); height: var(--switch-size); background: var(--Always-White); border-radius: 50%; transition: background-color 0.2s ease-in-out, transform 0.2s ease-in-out; display: block; }

.switch-icon.open[data-v-b063d6f3] { background: var(--Colors-KMBlue); }

.switch-icon.open[data-v-b063d6f3]::before { transform: translateX(var(--switch-size)); }

.switch:not(.disabled):hover .switch-icon[data-v-b063d6f3]::before { transform: scale(0.8); }

.switch:not(.disabled):hover .switch-icon.open[data-v-b063d6f3]::before { transform: translateX(var(--switch-size)) scale(.8); }
