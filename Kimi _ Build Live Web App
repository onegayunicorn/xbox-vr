.app { --kimi-window-top-offset: 0px; }

.app.has-sidebar .main { --kimi-sidebar-main-offset: 6px; --kimi-sidebar-main-top-offset: 6px; --kimi-sidebar-fixed-trigger-offset: 102px; }

.app.has-sidebar.enable-layout-animation .main { transition: margin-left 0.3s ease-in-out; }

.app.has-sidebar.sidebar-fixed-win { --kimi-sidebar-fixed-bar-left: 8px; }

.app.sidebar-fixed-win:not(.sidebar-settings) { --kimi-window-top-offset: 48px; }

.app.has-sidebar.sidebar-fixed-win:not(.sidebar-settings) .main { --kimi-sidebar-main-top-offset: var(--kimi-window-top-offset); }

.app.has-sidebar.sidebar-fixed-win:not(.sidebar-settings) .is-full-screen::before { content: ""; height: var(--kimi-sidebar-main-top-offset,48px); app-region: drag; display: block; }

body.is-work-desktop.is-desktop-win .image-preview-container .top-bar { top: 63px; }

.app.has-sidebar .sidebar-slot--fixed ~ .main { --kimi-sidebar-main-offset: 240px; }

.app.has-sidebar .sidebar-slot--fixed.is-collapsed ~ .main { --kimi-sidebar-main-offset: 6px; }

.app.has-sidebar .sidebar-slot--fixed.is-collapsed ~ .main .header-left { position: static; }

.app.has-sidebar .sidebar-slot--fixed.is-collapsed ~ .main .sidebar-main-trigger--fixed-placeholder.is-expanded { width: var(--kimi-sidebar-fixed-trigger-offset); }

@media (min-width: 1281px) {
  .app.has-sidebar .sidebar-slot--interactive.not-mobile ~ .main { --kimi-sidebar-main-offset: 240px; }
  .app.has-sidebar .sidebar-slot--interactive.not-mobile.is-collapsed ~ .main { --kimi-sidebar-main-offset: 6px; }
}

.app.sidebar-fixed-mac .main .layout-header { app-region: drag; margin-top: -6px; }

.desktop-no-drag { app-region: no-drag; }

.app.has-sidebar .main .sidebar-main-trigger--interactive { display: none; }

.app.has-sidebar .main .sidebar-main-trigger--fixed-placeholder { visibility: hidden; pointer-events: none; justify-content: flex-end; align-items: center; width: 0px; margin-left: 0px; display: flex; overflow: hidden; }

.app.has-sidebar.enable-layout-animation .main .sidebar-main-trigger--fixed-placeholder { transition: width 0.3s ease-in-out; }

.app.has-sidebar .main .claw-page-layout .header-left { max-width: calc(100% - 300px); }

@media (max-width: 560px) {
  .app.has-sidebar .main .claw-page-layout .header-left { max-width: calc(100% - 250px); }
}

.app.has-sidebar .sidebar-slot--interactive:not(.not-mobile) ~ .main .sidebar-main-trigger--interactive { display: flex; }

@media (max-width: 1280px) {
  .app.has-sidebar .sidebar-slot--interactive ~ .main .sidebar-main-trigger--interactive { display: flex; }
}

@media (min-width: 1281px) {
  .app.has-sidebar .sidebar-slot--interactive.not-mobile.is-collapsed ~ .main .sidebar-main-trigger--interactive { display: flex; }
