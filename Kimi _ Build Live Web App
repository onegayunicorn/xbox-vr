.app.enable-layout-animation .sidebar-shell .sidebar { transition: transform 0.3s ease-in-out; }

.sidebar-slot--fixed { width: 240px; max-width: 240px; }

.sidebar-slot--fixed .sidebar { width: 240px; box-shadow: none; opacity: 1; transform: translate(0px); }

.sidebar-slot--fixed.is-collapsed { max-width: 0px; overflow: hidden; }

